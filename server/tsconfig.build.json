{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "outDir": "../dist-server",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "declaration": false,
    "types": ["node"]
  },
  "include": [
    "./**/*.ts",
    "../api/_lib/**/*.ts",
    "../api/_routes/**/*.ts"
  ],
  "exclude": ["../api/**/*.test.ts"]
}
