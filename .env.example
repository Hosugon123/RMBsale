# 資料庫（正式環境必填）
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# 認證（正式環境必填，請使用長隨機字串）
JWT_SECRET=change-me-to-a-long-random-secret

# 管理員帳號（僅 db:seed 使用；正式庫請勿重複執行 seed）
ADMIN_USERNAME=ds001
ADMIN_PASSWORD=change-me-strong-password

# 操作員帳號（選填，僅 db:seed）
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=change-me-operator-password

# 伺服器
PORT=8080
NODE_ENV=production

# 啟動時自動補 schema（正式環境建議 0，改用手動 db:migrate）
RUN_STARTUP_DB_MAINTENANCE=0

# 備份（正式環境建議 gcs）
BACKUP_STORAGE=gcs
GCS_BUCKET_NAME=your-backup-bucket
BACKUP_CRON_SECRET=change-me-cron-secret

# 本機開發
VITE_DEV=0
VITE_USE_DEMO=false
