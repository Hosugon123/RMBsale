{
  "name": "rmbsale",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --mode demo",
    "dev:demo": "vite --host 127.0.0.1 --mode demo",
    "dev:online": "cross-env VITE_DEV=1 tsx watch --exclude \"vite.config.ts.timestamp-*\" server/index.ts",
    "dev:server": "cross-env NODE_ENV=production tsx server/index.ts",
    "build:server": "tsc -p server/tsconfig.build.json",
    "build": "tsc -p tsconfig.app.json --noEmit && tsc -p api/tsconfig.json --noEmit && vite build && npm run build:server",
    "start": "node dist-server/server/index.js",
    "stable": "node scripts/serve-dist.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "deploy:asia": "powershell -ExecutionPolicy Bypass -File scripts/deploy-cloud-run-asia.ps1",
    "migrate:asia": "powershell -ExecutionPolicy Bypass -File scripts/migrate-to-asia.ps1",
    "db:export-snapshot": "tsx scripts/export-db-snapshot.ts",
    "db:import-snapshot": "tsx scripts/import-db-snapshot.ts",
    "test": "vitest run --environment jsdom",
    "test:watch": "vitest --environment jsdom",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:check-isolation": "tsx scripts/check-database-isolation.ts",
    "db:purge-probe-wallet": "tsx scripts/purge-probe-wallet-data.ts",
    "db:reset-admin": "tsx scripts/reset-admin.ts",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "import:xlsx": "tsx scripts/xlsx-to-import.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.16.0",
    "@neondatabase/serverless": "^1.0.2",
    "@tanstack/react-query": "^5.90.10",
    "@types/compression": "^1.8.1",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.44.7",
    "express": "^4.21.2",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.2",
    "tailwind-merge": "^2.6.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.22",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.7",
    "jsdom": "^27.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.9",
    "xlsx": "^0.18.5"
  }
}
