# 複製為 .env.local（本機開發用，勿提交 git）
# 正式 Cloud Run 的 DATABASE_URL 只放在 GCP Secret rmbsale-database-url，勿貼到本機測試。

# development = 本機／測試；production = Cloud Run 部署
RMBSALE_ENV=development

# 本機測試專用 Neon（scripts/setup-neon-dev.ps1 會自動填入 rmbsale-dev）
DATABASE_URL=postgresql://user:pass@ep-dev-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# 正式庫 Neon host（僅 host，不含密碼），供 db:check-isolation 比對，防止本機誤連正式庫
# 執行 setup-neon-prod.ps1 後會印出此值
RMBSALE_PRODUCTION_DB_HOST=ep-prod-xxxx.ap-southeast-1.aws.neon.tech

JWT_SECRET=dev-only-change-me-local-jwt-secret
ADMIN_USERNAME=ds001
ADMIN_PASSWORD=1234
VITE_DEV=1
VITE_USE_DEMO=false

# 探測腳本預設只允許 http://127.0.0.1:8080；勿對正式網址執行
# PROBE_BASE_URL=http://127.0.0.1:8080
