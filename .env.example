DATABASE_URL="postgresql://user:password@host.neon.tech/db?sslmode=require"
JWT_SECRET="change-this-long-random-secret"
ADMIN_USERNAME="ds001"
ADMIN_PASSWORD="1234"
OPERATOR_USERNAME="operator"
OPERATOR_PASSWORD="operator123"

# 複製為 .env.local 後執行 npm run dev:online（Express + Vite，與 Cloud Run 相同架構）
# 僅要本機 localStorage 示範時：npm run dev:demo
# Cloud Run 正式環境：DATABASE_URL、JWT_SECRET 必填；PORT 由平台注入（預設 8080）

# 備份與排程（選填）
# BACKUP_STORAGE=local
# BACKUP_STORAGE=gcs
# GCS_BUCKET_NAME=your-bucket-name
# BACKUP_CRON_SECRET=long-random-cron-secret
